const TARGET = new Date('2026-05-01T11:00:00+02:00').getTime();
function tick(){
  const now = Date.now();
  let diff = Math.max(0, TARGET - now);
  const d = Math.floor(diff/86400000); diff %= 86400000;
  const h = Math.floor(diff/3600000);  diff %= 3600000;
  const m = Math.floor(diff/60000);    diff %= 60000;
  const s = Math.floor(diff/1000);
  document.getElementById('cdDays').textContent  = String(d).padStart(2,'0');
  document.getElementById('cdHours').textContent = String(h).padStart(2,'0');
  document.getElementById('cdMins').textContent  = String(m).padStart(2,'0');
  document.getElementById('cdSecs').textContent  = String(s).padStart(2,'0');
}
tick(); setInterval(tick, 1000);

/* ============ NAV SCROLL ============ */
const nav = document.getElementById('nav');
window.addEventListener('scroll', ()=>{
  nav.classList.toggle('scrolled', window.scrollY > 30);
});
document.getElementById('navBurger').addEventListener('click', ()=>{
  document.getElementById('navLinks').classList.toggle('open');
});
document.querySelectorAll('#navLinks a').forEach(a=>a.addEventListener('click',()=>{
  document.getElementById('navLinks').classList.remove('open');
}));

/* ============ FADE-UP OBSERVER ============ */
document.documentElement.classList.add('js-ready');
const io = new IntersectionObserver((entries)=>{
  entries.forEach(e=>{ if (e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
},{threshold:.05, rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.fade-up').forEach(el=>io.observe(el));
// Failsafe: if anything still hidden after 1.2s, reveal it
setTimeout(()=>{ document.querySelectorAll('.fade-up:not(.in)').forEach(el=>el.classList.add('in')); }, 1200);

/* ============ FORM ============ */
document.getElementById('reserveForm').addEventListener('submit', (e)=>{
  e.preventDefault();
  const name = document.getElementById('rName').value.trim();
  const email = document.getElementById('rEmail').value.trim();
  if (!name || !email){
    document.getElementById('rName').focus(); return;
  }
  document.getElementById('formSuccess').classList.add('show');
  e.target.reset();
});

/* alias #contact -> #visit for nav */
const contactAlias = document.getElementById('contact');
if (!contactAlias){
  const v = document.getElementById('visit');
  if (v) v.id = 'visit'; // keep
  // make #contact also resolve
  const stub = document.createElement('span'); stub.id='contact';
  document.getElementById('visit').prepend(stub);
}
</script>

