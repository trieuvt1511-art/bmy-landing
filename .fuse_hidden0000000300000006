<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="theme-color" content="#FF0D00" />
<title>B'my — Bánh mì Vietnamita, hecho en Madrid</title>
<meta name="description" content="B'my abre el 1 de mayo de 2026 en Moncloa, Madrid. Bánh mì y café vietnamita, hecho con recetas tradicionales y servido en el corazón de Madrid." />

<!-- Open Graph -->
<meta property="og:title" content="B'my — Bánh mì Vietnamita, hecho en Madrid" />
<meta property="og:description" content="Apertura 1 de mayo de 2026. Moncloa, Madrid." />
<meta property="og:type" content="website" />
<meta property="og:image" content="assets/illu-banhmi.png" />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Afacad:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Caveat:wght@500;700&display=swap" rel="stylesheet">

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="assets/logo-red.svg">

<style>
/* ============ RESET / TOKENS ============ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
img{max-width:100%;display:block}
button{font:inherit;cursor:pointer;border:none;background:none;color:inherit}
a{color:inherit;text-decoration:none}

:root{
  /* B'My Official Colour Palette (from CMYK .ai) */
  --cream:#FAFBFF;
  --cream-dark:#F0F4FF;
  --red:#FF0D00;          /* Primary Red — C0 M95 Y100 K0 */
  --red-dark:#D40B00;     /* Darker red for hover states */
  --brown:#531313;        /* Secondary Brown — C35 M85 Y85 K50 */
  --yellow:#FFAB00;       /* Secondary Orange — C0 M33 Y100 K0 */
  --yellow-light:#FFF266; /* Secondary Yellow — C0 M5 Y60 K0 */
  --blue:#3366FF;         /* Primary Blue — C80 M60 Y0 K0 */
  --deep-blue:#0019E6;    /* Secondary Dark Blue — C100 M90 Y10 K0 */
  --bright-blue:#D9F2FF;  /* Secondary Bright Blue — C15 M5 Y0 K0 */
  --green:#43CB00;        /* Supporting Green — C73 M18 Y100 K3 */
  --white:#ffffff;
  --black:#000000;        /* Supporting Black */

  --font-display:'Oswald', 'Arial Narrow', sans-serif;
  --font-body:'Afacad','Helvetica Neue',sans-serif;
  --font-script:'Caveat','Brush Script MT',cursive;

  --container:1280px;
  --radius:18px;
  --radius-lg:28px;
  --shadow-soft:0 14px 40px -18px rgba(83,19,19,.25);
  --shadow-card:0 10px 30px -15px rgba(0,0,0,.2);
  --transition:cubic-bezier(.2,.7,.2,1);
}

html,body{background:var(--cream);color:var(--brown);font-family:var(--font-body);font-size:18px;line-height:1.55;-webkit-font-smoothing:antialiased;overflow-x:hidden}

/* ============ TYPOGRAPHY ============ */
h1,h2,h3,h4{font-family:var(--font-display);font-weight:600;line-height:.95;letter-spacing:-.01em;color:var(--brown);text-transform:uppercase}
h1{font-size:clamp(48px, 8vw, 124px)}
h2{font-size:clamp(38px, 6vw, 88px)}
h3{font-size:clamp(24px, 3vw, 38px)}
h4{font-size:clamp(18px, 2vw, 22px)}
p{max-width:60ch}
.display-script{font-family:var(--font-script);text-transform:none;color:var(--blue);font-weight:700;letter-spacing:0;font-size:1.05em;line-height:1}
.eyebrow{font-family:var(--font-display);font-weight:500;text-transform:uppercase;letter-spacing:.18em;font-size:14px;color:var(--red);display:inline-flex;align-items:center;gap:10px}
.eyebrow::before{content:"";width:32px;height:2px;background:var(--red);display:inline-block}

/* ============ LAYOUT HELPERS ============ */
.container{width:100%;max-width:var(--container);margin:0 auto;padding:0 28px}
section{padding:120px 0;position:relative}
@media (max-width:768px){section{padding:80px 0}}

/* ============ BUTTONS ============ */
.btn{
  display:inline-flex;align-items:center;gap:10px;
  padding:18px 32px;border-radius:999px;
  font-family:var(--font-display);text-transform:uppercase;font-weight:600;letter-spacing:.06em;font-size:15px;
  background:var(--red);color:var(--cream);
  transition:transform .25s var(--transition), background .25s var(--transition), box-shadow .25s var(--transition);
  box-shadow:0 8px 20px -10px rgba(255,13,0,.6);
}
.btn:hover{transform:translateY(-2px);background:var(--red-dark);box-shadow:0 14px 30px -10px rgba(255,13,0,.5)}
.btn .arrow{display:inline-block;transition:transform .25s var(--transition)}
.btn:hover .arrow{transform:translateX(4px)}
.btn.secondary{background:transparent;color:var(--deep-blue);border:2px solid var(--deep-blue);box-shadow:none}
.btn.secondary:hover{background:var(--deep-blue);color:var(--cream)}
.btn.dark{background:var(--deep-blue);color:var(--cream);box-shadow:0 8px 20px -10px rgba(0,25,230,.6)}
.btn.dark:hover{background:#000FC0}

/* ============ NAVBAR ============ */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  padding:18px 0;
  background:rgba(250,251,255,.88);backdrop-filter:saturate(180%) blur(12px);
  -webkit-backdrop-filter:saturate(180%) blur(12px);
  border-bottom:1px solid rgba(83,19,19,.08);
  transition:padding .25s var(--transition);
}
.nav.scrolled{padding:12px 0}
.nav-inner{display:flex;align-items:center;justify-content:space-between;gap:24px}
.nav-logo{height:46px;width:auto;display:block;transition:transform .25s var(--transition)}
.nav-logo:hover{transform:rotate(-3deg) scale(1.04)}
.nav-links{display:flex;align-items:center;gap:38px;font-family:var(--font-display);font-weight:500;text-transform:uppercase;letter-spacing:.05em;font-size:14px}
.nav-links a{position:relative;padding:6px 0;transition:color .2s var(--transition)}
.nav-links a::after{content:"";position:absolute;left:0;bottom:0;height:2px;background:var(--red);width:0;transition:width .25s var(--transition)}
.nav-links a:hover{color:var(--red)}
.nav-links a:hover::after{width:100%}
.nav-right{display:flex;align-items:center;gap:18px}

/* lang switcher */
.lang-switcher{display:flex;align-items:center;gap:0;background:transparent;border:1.5px solid var(--deep-blue);border-radius:999px;padding:4px;font-family:var(--font-display);font-weight:600;font-size:12px;text-transform:uppercase;letter-spacing:.08em}
.lang-switcher button{padding:6px 11px;border-radius:999px;color:var(--brown);transition:all .2s var(--transition)}
.lang-switcher button.active{background:var(--deep-blue);color:var(--cream)}
.lang-switcher button:hover:not(.active){background:rgba(83,19,19,.08)}

.nav-burger{display:none;width:42px;height:42px;border-radius:50%;background:var(--brown);color:var(--cream);align-items:center;justify-content:center}
.nav-burger svg{width:18px;height:18px}

@media (max-width:980px){
  .nav-links{display:none;position:absolute;top:100%;left:0;right:0;background:var(--cream);flex-direction:column;padding:24px 28px;gap:18px;border-bottom:2px solid var(--brown)}
  .nav-links.open{display:flex}
  .nav-burger{display:inline-flex}
  .nav .btn{display:none}
}

/* ============ HERO ============ */
.hero{padding:150px 0 120px;position:relative;overflow:hidden;min-height:100vh;display:flex;align-items:center;
  background:
    radial-gradient(ellipse at 20% 0%, rgba(255,171,0,.18), transparent 55%),
    radial-gradient(ellipse at 90% 100%, rgba(255,13,0,.10), transparent 60%),
    var(--cream);
}
.hero::before{
  content:"";position:absolute;inset:0;pointer-events:none;z-index:0;
  background-image:radial-gradient(rgba(51,102,255,.06) 1px, transparent 1px);
  background-size:22px 22px;
  mask-image:linear-gradient(to bottom, black 50%, transparent 100%);
  -webkit-mask-image:linear-gradient(to bottom, black 50%, transparent 100%);
}
.hero-bg-shapes{position:absolute;inset:0;pointer-events:none;z-index:0}
.shape{position:absolute;border-radius:50%}
.shape.s1{width:420px;height:420px;background:#D9F2FF;top:-100px;right:-120px;opacity:.55}
.shape.s2{width:260px;height:260px;background:var(--bright-blue);bottom:60px;left:-80px;opacity:.6}
.shape.s3{width:140px;height:140px;background:rgba(51,102,255,.2);top:34%;right:30%;opacity:.35}

.hero-grid{position:relative;z-index:2;display:grid;grid-template-columns:1.05fr 1fr;gap:60px;align-items:center}
.hero-text{position:relative}
.hero-text h1{margin:18px 0 24px;color:var(--brown);font-weight:700}
.hero-text h1 .accent{color:var(--red);display:inline-block;transform:rotate(-2deg);position:relative;padding:0 .12em}
.hero-text h1 .accent::after{content:"";position:absolute;left:0;right:0;bottom:6px;height:18px;background:var(--yellow);z-index:-1;border-radius:6px}
.hero-text .lead{font-size:clamp(17px,1.6vw,20px);color:var(--brown);opacity:.85;max-width:46ch;margin-bottom:36px}
.hero-cta{display:flex;align-items:center;gap:18px;flex-wrap:wrap;margin-bottom:44px}

/* Hero photo collage */
.hero-visual{position:relative;display:flex;align-items:center;justify-content:center;min-height:560px}
.hero-photo{
  position:relative;width:100%;max-width:460px;
  border-radius:32px;overflow:hidden;
  box-shadow:0 40px 80px -30px rgba(83,19,19,.55), 0 18px 40px -20px rgba(0,0,0,.25);
  border:8px solid var(--white);
  transform:rotate(-1.5deg);
  z-index:2;
  animation:floaty 7s ease-in-out infinite;
}
.hero-photo img{width:100%;height:auto;display:block;aspect-ratio:3/4;object-fit:cover;object-position:center 40%}
.hero-photo::after{
  content:"";position:absolute;inset:0;pointer-events:none;
  box-shadow:inset 0 -120px 80px -60px rgba(83,19,19,.4);
}

/* Mascot floats next to photo */
.hero-mascot{
  position:absolute;width:200px;height:auto;z-index:3;
  bottom:-30px;left:-50px;
  filter:drop-shadow(0 18px 24px rgba(83,19,19,.3));
  animation:bob 6s ease-in-out infinite;
}
.hero-mascot img{width:100%;height:auto}
@keyframes bob{0%,100%{transform:translateY(0) rotate(-4deg)}50%{transform:translateY(-12px) rotate(2deg)}}
@keyframes floaty{0%,100%{transform:rotate(-1.5deg) translateY(0)}50%{transform:rotate(-1.5deg) translateY(-8px)}}

/* Sticker tags overlaying photo */
.hero-sticker{
  position:absolute;background:var(--brown);color:var(--cream);
  font-family:var(--font-display);text-transform:uppercase;font-weight:600;letter-spacing:.06em;font-size:12px;
  padding:10px 16px;border-radius:999px;z-index:4;
  box-shadow:0 10px 24px -10px rgba(0,0,0,.4);
  display:inline-flex;align-items:center;gap:8px;
}
.hero-sticker .dot-y{width:8px;height:8px;border-radius:50%;background:var(--yellow)}
.hero-sticker.s-coffee{top:30px;left:-20px;transform:rotate(-6deg);background:var(--brown)}
.hero-sticker.s-banhmi{bottom:90px;right:-30px;transform:rotate(4deg);background:var(--red)}

.hero-badge{
  position:absolute;background:var(--red);color:var(--cream);
  width:148px;height:148px;border-radius:50%;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  font-family:var(--font-display);text-transform:uppercase;text-align:center;padding:14px;line-height:1.05;
  animation:spin-slow 28s linear infinite;
  box-shadow:0 18px 40px -12px rgba(255,13,0,.55), 0 0 0 6px var(--cream);
  z-index:5;
}
.hero-badge.opening{top:-20px;right:-30px}
.hero-badge .big{font-size:30px;font-weight:700;line-height:1;margin:4px 0}
.hero-badge .small{font-size:10px;letter-spacing:.12em;font-weight:500}
@keyframes spin-slow{0%{transform:rotate(-8deg)}50%{transform:rotate(8deg)}100%{transform:rotate(-8deg)}}

@media (max-width:980px){
  .hero{padding:130px 0 80px}
  .hero-grid{grid-template-columns:1fr;gap:40px;text-align:center}
  .hero-text .lead{margin-left:auto;margin-right:auto}
  .hero-cta{justify-content:center}
  .hero-visual{min-height:480px}
  .hero-photo{max-width:340px}
  .hero-mascot{width:140px;left:-20px;bottom:-20px}
  .hero-badge.opening{top:-10px;right:-10px;width:120px;height:120px}
  .hero-badge .big{font-size:24px}
  .hero-sticker.s-coffee{top:10px;left:0}
  .hero-sticker.s-banhmi{bottom:80px;right:-10px}
}

/* ============ COUNTDOWN ============ */
.countdown{display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-top:8px}
.countdown-label{font-family:var(--font-display);text-transform:uppercase;font-weight:500;letter-spacing:.12em;font-size:12px;color:var(--brown);opacity:.7}
.countdown-grid{display:flex;align-items:stretch;gap:10px}
.cd-cell{
  background:var(--brown);color:var(--cream);
  border-radius:14px;padding:14px 14px 10px;text-align:center;min-width:74px;
  box-shadow:0 8px 20px -12px rgba(0,0,0,.4);
}
.cd-cell .num{font-family:var(--font-display);font-weight:700;font-size:36px;line-height:1;display:block;letter-spacing:-.02em}
.cd-cell .lbl{font-size:10px;letter-spacing:.16em;text-transform:uppercase;opacity:.7;margin-top:6px;display:block}
@media (max-width:980px){.countdown{justify-content:center}.cd-cell{min-width:64px;padding:12px 10px 8px}.cd-cell .num{font-size:30px}}

/* ============ MARQUEE ============ */
.marquee{
  background:var(--red);color:var(--cream);
  padding:22px 0;overflow:hidden;
  border-top:3px solid var(--brown);border-bottom:3px solid var(--brown);
  transform:rotate(-1.5deg);margin:0 -20px;
  position:relative;z-index:10;
}
.marquee-inner{display:flex;gap:60px;animation:marquee 28s linear infinite;white-space:nowrap;font-family:var(--font-display);text-transform:uppercase;font-weight:600;font-size:32px;letter-spacing:.04em}
.marquee-inner span{display:inline-flex;align-items:center;gap:60px}
.marquee-inner .dot{display:inline-block;width:18px;height:18px;border-radius:50%;background:var(--yellow)}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ============ TASTE GALLERY ============ */
.taste{padding:100px 0;background:var(--brown);position:relative;overflow:hidden}
.taste::before{content:"";position:absolute;inset:0;
  background-image:radial-gradient(rgba(51,102,255,.06) 1px, transparent 1px);
  background-size:20px 20px;pointer-events:none;
}
.taste-head{text-align:center;margin-bottom:60px;position:relative;z-index:1}
.taste-head .eyebrow{color:var(--yellow);margin-bottom:14px;justify-content:center}
.taste-head .eyebrow::before,.taste-head .eyebrow::after{background:var(--yellow)}
.taste-head h2{color:var(--cream);max-width:14ch;margin:0 auto 18px}
.taste-head p{color:var(--cream);opacity:.7;margin:0 auto;font-size:18px}
.taste-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:22px;position:relative;z-index:1}
.taste-card{
  border-radius:22px;overflow:hidden;position:relative;
  box-shadow:0 20px 50px -20px rgba(0,0,0,.5);
  transition:transform .4s var(--transition), box-shadow .4s var(--transition);
}
.taste-card:hover{transform:translateY(-6px) scale(1.02);box-shadow:0 30px 60px -20px rgba(0,0,0,.6)}
.taste-card img{width:100%;height:100%;object-fit:cover;object-position:center center;display:block}
.taste-card.tall{grid-row:span 2;min-height:480px}
.taste-card.wide{grid-column:span 2;min-height:260px}
.taste-card .caption{
  position:absolute;bottom:0;left:0;right:0;
  padding:60px 22px 22px;
  background:linear-gradient(to top, rgba(0,0,0,.7), transparent);
  color:var(--cream);
  font-family:var(--font-display);font-weight:600;text-transform:uppercase;letter-spacing:.06em;font-size:14px;
}
.taste-card .caption .script{display:block;font-family:var(--font-script);text-transform:none;font-weight:500;font-size:22px;color:var(--yellow);letter-spacing:0;margin-top:4px}
.taste-card-illu{background:var(--red);display:flex;align-items:center;justify-content:center;padding:30px}
.taste-card-illu img{width:80%;max-width:200px;height:auto;object-fit:contain;filter:drop-shadow(0 10px 20px rgba(0,0,0,.3))}

@media (max-width:980px){
  .taste-grid{grid-template-columns:1fr 1fr;gap:16px}
  .taste-card.tall{min-height:320px}
  .taste-card.wide{grid-column:auto;min-height:200px}
}
@media (max-width:560px){
  .taste-grid{grid-template-columns:1fr;gap:14px}
  .taste-card.tall{min-height:300px}
}

/* ============ STORY ============ */
.story{background:var(--cream-dark);position:relative;overflow:hidden}
.story::before{content:"";position:absolute;top:-80px;right:-80px;width:280px;height:280px;border-radius:50%;background:var(--yellow);opacity:.35}
.story-grid{display:grid;grid-template-columns:1fr 1.1fr;gap:80px;align-items:center;position:relative;z-index:1}
.story-visual{position:relative;display:flex;justify-content:center;align-items:center}
.story-photo-stack{position:relative;width:100%;max-width:460px;margin:0 auto}
.story-photo-main{
  border-radius:28px;overflow:hidden;
  transform:rotate(2deg);
  box-shadow:0 30px 60px -25px rgba(83,19,19,.45), 0 0 0 8px var(--white);
}
.story-photo-main img{width:100%;height:auto;display:block;aspect-ratio:4/3;object-fit:cover}
.story-photo-accent{
  position:absolute;width:200px;border-radius:20px;overflow:hidden;
  bottom:-30px;left:-40px;z-index:2;transform:rotate(-5deg);
  box-shadow:0 20px 40px -15px rgba(0,0,0,.4), 0 0 0 6px var(--white);
}
.story-photo-accent img{width:100%;height:auto;display:block;aspect-ratio:1/1;object-fit:cover}
.story-mascot-float{
  position:absolute;width:160px;top:-40px;right:-40px;z-index:3;
  filter:drop-shadow(0 14px 20px rgba(83,19,19,.25));
  animation:bob 6s ease-in-out infinite;
}
.story-mascot-float img{width:100%;height:auto}

.story-text h2{margin:20px 0 28px}
.story-text p{color:var(--brown);opacity:.88;margin-bottom:18px;font-size:18px;line-height:1.7}
.story-text p strong{color:var(--red);font-weight:700}
.story-signoff{margin-top:32px;display:flex;align-items:center;gap:18px}
.story-signoff .sig{font-family:var(--font-script);font-size:34px;color:var(--red);line-height:1}
.story-signoff .who{font-family:var(--font-display);font-size:13px;text-transform:uppercase;letter-spacing:.1em;opacity:.7}

@media (max-width:980px){
  .story-grid{grid-template-columns:1fr;gap:40px;text-align:center}
  .story-signoff{justify-content:center}
  .story-text p{margin-left:auto;margin-right:auto}
  .story-photo-accent{width:140px;left:-10px;bottom:-20px}
  .story-mascot-float{width:120px;top:-20px;right:-10px}
}

/* ============ MENU ============ */
.menu-section{
  background:var(--cream);
  position:relative;overflow:hidden;
}
.menu-section::before{
  content:"";position:absolute;top:60px;left:50%;transform:translateX(-50%);
  width:600px;height:600px;border-radius:50%;
  background:radial-gradient(circle, rgba(255,171,0,.12), transparent 70%);
  pointer-events:none;
}
.menu-head{text-align:center;margin-bottom:64px;position:relative;z-index:1}
.menu-head .eyebrow{margin-bottom:16px;justify-content:center}
.menu-head .eyebrow::before,.menu-head .eyebrow::after{content:"";width:32px;height:2px;background:var(--red);display:inline-block}
.menu-head h2{max-width:18ch;margin:0 auto 18px}
.menu-head p{margin:0 auto;opacity:.8;font-size:18px}

.menu-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:30px;position:relative;z-index:1}
.menu-card{
  background:var(--white);border-radius:var(--radius-lg);padding:0;
  box-shadow:var(--shadow-card);position:relative;
  border:2px solid transparent;transition:all .4s var(--transition);overflow:hidden;
}
.menu-card-head{
  position:relative;padding:38px 32px 14px;
  background:linear-gradient(180deg, rgba(255,171,0,.08) 0%, transparent 100%);
}
.menu-card:nth-child(1) .menu-card-head{background:linear-gradient(180deg, rgba(255,13,0,.06) 0%, transparent 100%)}
.menu-card:nth-child(3) .menu-card-head{background:linear-gradient(180deg, rgba(51,102,255,.06) 0%, transparent 100%)}
.menu-card::before{
  content:"";position:absolute;top:0;left:0;right:0;height:6px;
  background:var(--red);z-index:1;
}
.menu-card:nth-child(2)::before{background:var(--yellow)}
.menu-card:nth-child(3)::before{background:var(--blue)}
.menu-card:hover{transform:translateY(-8px);border-color:var(--brown);box-shadow:0 32px 60px -20px rgba(83,19,19,.3)}
.menu-card .icon{width:130px;height:130px;margin:0 auto 8px;display:block;filter:drop-shadow(0 10px 16px rgba(83,19,19,.15));transition:transform .4s var(--transition)}
.menu-card:hover .icon{transform:scale(1.06) rotate(-3deg)}
.menu-card h3{text-align:center;margin-bottom:8px;color:var(--brown);font-size:clamp(26px,3vw,36px)}
.menu-card .sub{text-align:center;font-family:var(--font-script);color:var(--red);font-size:24px;margin-bottom:0}
.menu-card-body{padding:24px 32px 32px}
.menu-card ul{list-style:none;display:flex;flex-direction:column;gap:14px}
.menu-card li{display:flex;justify-content:space-between;align-items:baseline;gap:14px;padding-bottom:14px;border-bottom:1px dashed rgba(83,19,19,.15);font-size:16px}
.menu-card li:last-child{border-bottom:0;padding-bottom:0}
.menu-card li .name{font-weight:600;color:var(--brown);flex:1}
